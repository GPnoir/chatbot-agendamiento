# Chatbot Agendamiento — environment variable reference
# Copy to .env and fill in real values. NEVER commit .env.

# == Runtime ==
# Log verbosity. Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Consumed by aws-lambda-powertools Logger (LOG_LEVEL env var).
LOG_LEVEL=INFO

RATE_LIMITER_BACKEND=memory
RATE_LIMIT_MAX_MESSAGES=20
RATE_LIMIT_WINDOW_SECONDS=60

# Maximum allowed message length (characters, measured after sanitization).
# Messages longer than this value are rejected with a polite user-facing reply.
MAX_MESSAGE_LENGTH=500

# == Security / CORS ==
# Comma-separated list of allowed CORS origins.
# Leave empty (default) to disable cross-origin access entirely.
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# == Tokens and secrets ==
# TELEGRAM_WEBHOOK_SECRET and WHATSAPP_VERIFY_TOKEN are required and have no
# defaults (template.yaml enforces MinLength). Webhook validation fails closed:
# an empty value rejects every request with 403.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
ADMIN_API_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# == Infrastructure ==
DYNAMODB_TABLE=chatbot-agendamiento
WEBHOOK_URL=https://your-api-gateway-url.execute-api.region.amazonaws.com/Prod
HOST=0.0.0.0
PORT=8000

# == Business ==
ADMIN_USER_ID=
MAX_CITAS_POR_CLIENTE=3

# == Google Calendar (issue #14) ==
# Sync best-effort de citas al calendar del profesional vía OAuth2 refresh token.
# Opt-in: dejá GOOGLE_CALENDAR_ENABLED=false (o vacío) y todo es no-op.
# Para obtener el refresh token la primera vez:
#   python scripts/get_google_refresh_token.py
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Calendar destino: 'primary' o la dirección del calendario (e.g. abc@group.calendar.google.com)
GOOGLE_CALENDAR_ID=primary
# Timezone IANA para los eventos (Chile por defecto).
GOOGLE_CALENDAR_TIMEZONE=America/Santiago
